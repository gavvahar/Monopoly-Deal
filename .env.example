# Web Application Configuration
PROD_WEB_PORT=8001
DEV_WEB_PORT=8002
LOCAL_WEB_PORT=8003

# Authentik SSO Configuration
AUTHENTIK_URL=https://your-authentik-instance.com
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_REDIRECT_URI=http://localhost:8001/auth/callback

# Database Configuration
POSTGRES_USER=monopoly_user
POSTGRES_PASSWORD=monopoly_password
POSTGRES_DB=monopoly_deal

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@monopoly.com
PGADMIN_DEFAULT_PASSWORD=admin_password