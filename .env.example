# Web Application Configuration
PROD_WEB_PORT=8001
DEV_WEB_PORT=8002
LOCAL_WEB_PORT=8003

# Authentik SSO Configuration (used in prod and dev profiles; set automatically by Docker Compose)
# SSO_ENABLED=true
AUTHENTIK_URL=https://your-authentik-instance.com
AUTHENTIK_CLIENT_ID=your-client-id
AUTHENTIK_CLIENT_SECRET=your-client-secret
AUTHENTIK_REDIRECT_URI=http://localhost:8001/auth/callback
AUTHENTIK_APP_SLUG=your-app-slug
AUTHENTIK_ADMIN_GROUP=Monopoly_Deal_Dev_Admins
AUTHENTIK_USER_GROUP=Monopoly_Deal_Dev_Users

# Database Configuration
POSTGRES_USER=monopoly_user
POSTGRES_PASSWORD=monopoly_password
POSTGRES_DB=monopoly_deal
# DB_HOST is set automatically per profile (db-prod / db-dev) — override only if needed
# DB_HOST=db-prod

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@monopoly.com
PGADMIN_DEFAULT_PASSWORD=admin_password

# Local Profile Users (seeded automatically on startup, only used when SSO_ENABLED=false)
LOCAL_USER=player
LOCAL_USER_PASSWORD=changeme
LOCAL_ADMIN_USER=admin
LOCAL_ADMIN_PASSWORD=changeme